{
  "$schema": "EcoTrace design tokens v1 — branding workspace (no wired to web yet)",
  "meta": {
    "name": "EcoTrace",
    "version": "1.0.0-brand-draft",
    "notes": "Direction: Swiss software, light-first marketing. Green anchor #059669; no gold in core palette. Align logo assets with design when exports updated."
  },
  "color": {
    "brand": {
      "green": { "value": "#059669", "description": "Primary sustainability / brand anchor (emerald forest)" },
      "greenDark": { "value": "#047857", "description": "Hover, emphasis, dark UI accents" },
      "greenDeepest": { "value": "#022C22", "description": "Deep green surfaces, dark headers optional" }
    },
    "neutral": {
      "white": { "value": "#FFFFFF" },
      "canvas": { "value": "#F8FAFC", "description": "Page background alternate" },
      "slate50": { "value": "#F1F5F9" },
      "slate200": { "value": "#E2E8F0", "description": "Borders default light" },
      "slate400": { "value": "#94A3B8", "description": "Secondary text, placeholders" },
      "slate600": { "value": "#475569", "description": "Body secondary" },
      "ink": { "value": "#0F172A", "description": "Primary text / headings (slate-900)" }
    },
    "semantic": {
      "success": { "value": "#059669" },
      "warning": { "value": "#D97706" },
      "danger": { "value": "#DC2626" },
      "info": { "value": "#0369A1" }
    }
  },
  "typography": {
    "fontFamily": {
      "sans": { "value": "Inter, ui-sans-serif, system-ui, sans-serif" },
      "display": { "value": "Inter, ui-sans-serif, system-ui, sans-serif", "note": "Optional: swap display to geometric sans after license decision (e.g. custom corporate font)" }
    },
    "scale": {
      "xs": { "fontSize": "0.75rem", "lineHeight": "1rem", "letterSpacing": "0.02em" },
      "sm": { "fontSize": "0.875rem", "lineHeight": "1.25rem" },
      "base": { "fontSize": "1rem", "lineHeight": "1.5rem" },
      "lg": { "fontSize": "1.125rem", "lineHeight": "1.75rem" },
      "xl": { "fontSize": "1.25rem", "lineHeight": "1.75rem", "fontWeight": 500 },
      "2xl": { "fontSize": "1.5rem", "lineHeight": "2rem", "fontWeight": 500, "letterSpacing": "-0.02em" },
      "3xl": { "fontSize": "1.875rem", "lineHeight": "2.25rem", "fontWeight": 500, "letterSpacing": "-0.02em" },
      "4xl": { "fontSize": "2.25rem", "lineHeight": "2.5rem", "fontWeight": 500, "letterSpacing": "-0.03em" },
      "5xl": { "fontSize": "3rem", "lineHeight": "1.1", "fontWeight": 500, "letterSpacing": "-0.03em" }
    }
  },
  "spacing": {
    "unit": 8,
    "scale": [0, 4, 8, 12, 16, 24, 32, 40, 48, 64, 80, 96]
  },
  "radius": {
    "sm": "4px",
    "md": "6px",
    "lg": "8px",
    "xl": "12px"
  },
  "shadow": {
    "sm": "0 1px 2px 0 rgb(15 23 42 / 0.05)",
    "DEFAULT": "0 1px 3px 0 rgb(15 23 42 / 0.08), 0 1px 2px -1px rgb(15 23 42 / 0.08)",
    "md": "0 4px 6px -1px rgb(15 23 42 / 0.08), 0 2px 4px -2px rgb(15 23 42 / 0.06)",
    "lg": "0 10px 15px -3px rgb(15 23 42 / 0.08), 0 4px 6px -4px rgb(15 23 42 / 0.05)",
    "xl": "0 20px 25px -5px rgb(15 23 42 / 0.08), 0 8px 10px -6px rgb(15 23 42 / 0.04)"
  },
  "layout": {
    "grid": { "columns": 12, "gutter": "24px", "maxWidth": "72rem" }
  }
}
