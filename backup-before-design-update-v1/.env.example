CARBON_INTERFACE_API_KEY=
DATABASE_URL=sqlite:///./ecotrace.db
JWT_SECRET=change-me-in-dev
JWT_ALG=HS256

# --- Carbon engine (optional overrides; defaults match backend/app/config.py) ---
CARBON_PRICE_EUR_PER_TONNE=110
LOAD_FACTOR=0.75
LONGHAUL_KM_THRESHOLD=1000
RADIATIVE_FORCING_AIR_MULTIPLIER=1.9
UNCERTAINTY_LONGHAUL_MULTIPLIER=1.1
RETURNS_LOGISTICS_MULTIPLIER=2.0
RETURNS_DILUTION_FACTOR=0.9
ECOTRACE_FEE_FIXED_EUR=0.12
ECOTRACE_FEE_PCT_ON_COMPENSATION=0.05
ECOTRACE_FEE_MIN_EUR=0.02
# Merge into default category return rates, e.g. {"books":0.11}
ECOTRACE_RETURN_RATES_JSON=

# --- Cron reconciliación mensual + wallet ---
CRON_SECRET=
# true para APScheduler en el mismo proceso uvicorn (día 2, 03:00 UTC por defecto)
RECONCILIATION_SCHEDULER_ENABLED=false
RECONCILIATION_CRON_DAY=2
RECONCILIATION_CRON_HOUR=3
RECONCILIATION_CRON_MINUTE=0

# --- Email opcional (notificación post-reconciliación; si vacío solo se registra en log) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_EMAIL_FROM=
